# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq AI API calls (Llama models).
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Whop Plan Product IDs
WHOP_STARTER_PRODUCT_ID="prod_xxxx"
WHOP_GROWTH_PRODUCT_ID="prod_xxxx"
WHOP_SCALE_PRODUCT_ID="prod_xxxx"

# Whop Add-on Product IDs
WHOP_ADDON_EMAILS_10K_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_EMAILS_50K_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_CONTACTS_1K_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_CONTACTS_5K_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_AI_50_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_AI_200_PRODUCT_ID="prod_xxxx"

# Whop AI Credit Pack Product IDs (Legacy/Alternative)
WHOP_ADDON_AI_STARTER_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_AI_PRO_PRODUCT_ID="prod_xxxx"
WHOP_ADDON_AI_UNLIMITED_PRODUCT_ID="prod_xxxx"

# Cron Secret for monthly AI credit resets
CRON_SECRET="generate-a-random-secret-here"

# Resend API Key for email sending
RESEND_API_KEY="re_xxxx"
RESEND_FROM_EMAIL="verify@revtray.com"
RESEND_FROM_NAME="RevTray"

# NameSilo API Key for domain search/pricing
NAMESILO_API_KEY=

# Whop API Key for revenue tracking and member sync
WHOP_API_KEY="whop_xxxx"

# Whop Webhook Secret for verifying incoming webhooks
WHOP_WEBHOOK_SECRET="wh_xxxx"

# Database URL for Prisma
DATABASE_URL="postgresql://user:password@host:port/dbname"

# NextAuth Secret for session encryption
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Preview Mode (Local Dev)
PREVIEW_MODE=true
NEXT_PUBLIC_PREVIEW_MODE=true

# Staging Bypass (Vercel)
# 1. Set NEXT_PUBLIC_STAGING_MODE=true
# 2. Set STAGING_BYPASS_TOKEN to a long random secret
# 3. Visit dev.revtray.com/api/auth/staging?token=YOUR_SECRET to "log in"
NEXT_PUBLIC_STAGING_MODE=false
STAGING_BYPASS_TOKEN=

# Sentry (Error Tracking)
# Create a project at sentry.io to get your DSN
NEXT_PUBLIC_SENTRY_DSN=

# Logging (BetterStack)
# info, warn, error
LOG_LEVEL=info

# PostHog (Analytics & Feature Flags)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Admin Access
# Comma-separated list of emails with platform-wide administrative access
ADMIN_EMAILS=bauxiticstar7546@gmail.com
