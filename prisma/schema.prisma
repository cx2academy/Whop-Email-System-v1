// prisma/schema.prisma
//
// Whop Email Engine — Full Database Schema
//
// Database Principles enforced:
//   ✅ Every tenant-scoped table includes workspaceId
//   ✅ UUIDs for all primary keys
//   ✅ createdAt + updatedAt on all tables
//   ✅ Foreign keys indexed
//   ✅ Unique constraint: (workspaceId, email) on Contact
//   ✅ Schema designed for high-volume email sends
//   ✅ Future-ready for segmentation, webhooks, automation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// AUTH — NextAuth v5 / Auth.js adapter tables
// ---------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // LOGIN_SUCCESS, LOGIN_FAILURE, PASSWORD_CHANGE, MFA_ENABLE, etc.
  ipAddress   String?
  userAgent   String?
  metadata    Json?    // Optional extra context (e.g. { provider: 'credentials' })
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  firstName     String?
  lastName      String?
  phoneNumber   String?   @unique
  dob           DateTime?
  image         String?
  passwordHash  String?   // null for OAuth-only users
  
  // Security
  failedLoginAttempts  Int       @default(0)
  lockoutUntil         DateTime?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?   @db.Text
  twoFactorBackupCodes String?   @db.Text // JSON string of backup codes

  // Marketing & Compliance
  termsAccepted      Boolean   @default(false)
  marketingConsent   Boolean   @default(false)
  persona            String?
  heardAboutUs       String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  
  hasAchievedFirstSend Boolean @default(false)
  onboardingDismissedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships WorkspaceMembership[]
  notifications Notification[]
  auditLogs   AuditLog[]
  betaFeedbacks BetaFeedback[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  expiresAt   DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("invite_codes")
}

model BetaWaitlist {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  reason          String   @db.Text
  acceptedPledge  Boolean  @default(false)
  status          BetaWaitlistStatus @default(PENDING)
  inviteCode      String?  // The code generated upon approval
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("beta_waitlist")
}

enum BetaWaitlistStatus {
  PENDING
  APPROVED
  REJECTED
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// WORKSPACE — Top-level multi-tenant boundary
// ---------------------------------------------------------------------------

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // Whop integration
  whopApiKey      String?
  whopCompanyId   String?
  whopCompanyName String?   // ← NEW: auto-populated from Whop API on key save
  webhookSecret   String?

  // Branding — used in email templates and onboarding UI
  logoUrl    String?                   // ← NEW: workspace logo URL
  brandColor String @default("#22C55E") // ← NEW: hex color for email CTAs
  niche      String?                   // ← NEW: community niche for AI context

  // Sending identity defaults
  fromEmail String?
  fromName  String?
  physicalAddress String? // ← NEW: Required for CAN-SPAM compliance
  unsubscribeRedirectUrl String? // ← NEW: Optional custom redirect after unsubscribe
  
  // Custom API Keys (BYOK Beta)
  resendApiKey String?

  // Plan / limits
  plan            WorkspacePlan @default(FREE)
  monthlyEmailCap Int           @default(1000)
  aiCredits       Int           @default(10)
  aiCreditsLastReset DateTime   @default(now())

  // BYOK Beta Quest Flags
  questDomainSetup   Boolean @default(false)
  questImportedLeads Boolean @default(false)
  questUsedAi        Boolean @default(false)
  questSentCampaign  Boolean @default(false)

  // Whop billing fields
  whopMembershipId   String?
  whopPlanProductId  String?
  billingStatus      String    @default("free")
  billingPeriodEnd   DateTime?
  trialEndsAt        DateTime?

  // Smart sending settings
  engagementFilterEnabled Boolean @default(true)
  engagementFilterDays    Int     @default(30)
  deduplicationEnabled    Boolean @default(true)
  sendRateLimitEnabled    Boolean @default(false)
  sendRateLimitPerMinute  Int     @default(100)
  abuseDetectionEnabled   Boolean @default(true)

  // Abuse flags
  abuseFlagged        Boolean   @default(false)
  abuseFlaggedReason  String?
  abuseFlaggedAt      DateTime?

  // AI Brand Voice
  voiceProfile        String?   @db.Text
  voiceProfileBuiltAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         WorkspaceMembership[]
  contacts            Contact[]
  campaigns           EmailCampaign[]
  emailSends          EmailSend[]
  syncLogs            SyncLog[]
  apiKeys             ApiKey[]
  telemetryEvents     TelemetryEvent[]
  sendingDomains      SendingDomain[]
  automationWorkflows AutomationWorkflow[]
  segments            Segment[]
  purchases           Purchase[]
  notifications       Notification[]
  attributions        RevenueAttribution[]
  clickEvents         ClickEvent[]
  emailTemplates      EmailTemplate[]
  tags                Tag[]
  emailProviderConfig EmailProviderConfig?
  domainSearchLogs    DomainSearchLog[]
  aiCreditLogs        AiCreditLog[]
  addons              WorkspaceAddon[]
  campaignInsights    CampaignInsight[]
  webhookLogs         WebhookLog[]
  betaFeedbacks       BetaFeedback[]

  @@index([slug])
  @@map("workspaces")
}

enum WorkspacePlan {
  FREE
  STARTER
  GROWTH
  PRO
  ENTERPRISE
  SCALE
}

// ---------------------------------------------------------------------------
// WORKSPACE MEMBERSHIP
// ---------------------------------------------------------------------------

model WorkspaceMembership {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_memberships")
}

// ---------------------------------------------------------------------------
// BETA FEEDBACK
// ---------------------------------------------------------------------------
model BetaFeedback {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  feature     String
  rating      Int
  feedback    String?  @db.Text
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@map("beta_feedback")
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ---------------------------------------------------------------------------
// CONTACT
// ---------------------------------------------------------------------------

model Contact {
  id          String @id @default(cuid())
  workspaceId String

  email     String
  firstName String?
  lastName  String?

  whopMemberId String?
  whopStatus   String?
  whopPasses   String[]
  whopMetadata Json?

  status ContactStatus @default(SUBSCRIBED)

  unsubscribedAt DateTime?
  unsubscribeIp  String?

  peakEngagementHour   Int?
  peakEngagementDay    Int?
  engagementAnalyzedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags                  ContactTag[]
  emailSends            EmailSend[]
  automationEnrollments AutomationEnrollment[]
  purchases             Purchase[]
  attributions          RevenueAttribution[]
  clickEvents           ClickEvent[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([whopMemberId])
  @@map("contacts")
}

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

// ---------------------------------------------------------------------------
// TAG
// ---------------------------------------------------------------------------

model Tag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// ---------------------------------------------------------------------------
// EMAIL CAMPAIGN
// ---------------------------------------------------------------------------

model EmailCampaign {
  id          String @id @default(cuid())
  workspaceId String
  sendViaEmail  Boolean @default(true)
  sendViaWhopDm Boolean @default(false)
  name        String
  type        CampaignType   @default(BROADCAST)
  status      CampaignStatus @default(DRAFT)

  subject     String
  previewText String?
  htmlBody    String  @db.Text
  textBody    String? @db.Text

  audienceTagIds     String[]
  audienceSegmentIds String[]

  sendTimeOptimized Boolean @default(false)

  isAbTest        Boolean @default(false)
  templateId      String?
  sequenceId      String?
  isApproved      Boolean @default(false)
  abSubjectB      String?
  abWinnerVariant String?

  abTestVariantA      String?
  abTestVariantB      String?
  abTestSplitPercent  Int @default(20)
  abTestWinnerPicked  Boolean @default(false)
  abTestWinnerSubject String?
  abTestWinnerPickedAt DateTime?
  abTestSentACount    Int @default(0)
  abTestSentBCount    Int @default(0)
  abTestOpenedACount  Int @default(0)
  abTestOpenedBCount  Int @default(0)
  abTestStatus        String @default("idle")
  abTestRemainingContactIds String[]

  scheduledAt DateTime?
  sentAt      DateTime?

  totalRecipients Int @default(0)
  totalSent       Int @default(0)
  totalOpened     Int @default(0)
  totalClicked    Int @default(0)
  totalBounced    Int @default(0)
  totalFailed     Int @default(0)
  totalUnsubscribed Int @default(0)
  totalRevenue    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emailSends           EmailSend[]
  attributions         RevenueAttribution[]
  clickEvents          ClickEvent[]
  deliverabilityReport DeliverabilityReport?
  inboxTestResults     InboxTestResult[]
  insight              CampaignInsight?

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([scheduledAt])
  @@map("email_campaigns")
}

model CampaignInsight {
  id          String @id @default(cuid())
  workspaceId String
  campaignId  String @unique
  type        String  // 'unsubscribe_risk' | 'low_engagement' | 'strong_performer'
  headline    String
  insight     String  // 2-3 sentence analysis
  riskFactors String  // JSON: string[]
  confidence  String  // 'high' | 'medium' | 'low'
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  @@index([workspaceId])
  @@map("campaign_insights")
}

enum CampaignType {
  BROADCAST
  DRIP
  TRIGGER
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  PAUSED
}

// ---------------------------------------------------------------------------
// EMAIL SEND
// ---------------------------------------------------------------------------

model EmailSend {
  id          String @id @default(cuid())
  workspaceId String
  campaignId  String
  contactId   String

  status   EmailSendStatus @default(PENDING)
  provider EmailProvider   @default(RESEND)

  messageId     String?
  failureReason String? @db.Text

  idempotencyKey String @unique

  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?

  bounceType   String?
  bounceReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact   Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([contactId])
  @@index([workspaceId, status])
  @@index([idempotencyKey])
  @@index([messageId])
  @@map("email_sends")
}

enum EmailSendStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  UNSUBSCRIBED
}

enum EmailProvider {
  RESEND
  SMTP
  SES
  SENDGRID
}

// ---------------------------------------------------------------------------
// SYNC LOG
// ---------------------------------------------------------------------------

model SyncLog {
  id          String @id @default(cuid())
  workspaceId String

  status      SyncStatus @default(RUNNING)
  triggeredBy String?

  totalFetched  Int @default(0)
  totalUpserted Int @default(0)
  totalSkipped  Int @default(0)
  totalErrors   Int @default(0)

  errorDetails Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ---------------------------------------------------------------------------
// API KEY
// ---------------------------------------------------------------------------

model ApiKey {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String  @unique
  keyPrefix   String
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs      ApiLog[]

  @@index([workspaceId])
  @@map("api_keys")
}

model ApiLog {
  id         String @id @default(cuid())
  apiKeyId   String
  method     String
  path       String
  statusCode Int
  durationMs Int

  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
  @@map("api_logs")
}

// ---------------------------------------------------------------------------
// TELEMETRY EVENT
// ---------------------------------------------------------------------------

model TelemetryEvent {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String?

  event      String
  properties String @default("{}")

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, event, createdAt])
  @@index([createdAt])
  @@map("telemetry_events")
}

// ---------------------------------------------------------------------------
// SENDING DOMAIN
// ---------------------------------------------------------------------------

model SendingDomain {
  id          String  @id @default(cuid())
  workspaceId String
  domain      String

  // DNS authentication status (legacy + Resend-verified)
  spfVerified        Boolean @default(false)
  dkimVerified       Boolean @default(false)
  dmarcVerified      Boolean @default(false)
  returnPathVerified Boolean @default(false)

  // Legacy DKIM fields (kept for backwards compat with non-Resend domains)
  dkimSelector   String  @default("wee1")
  dkimPublicKey  String? @db.Text
  dkimPrivateKey String? @db.Text

  // Provider hint
  emailProvider String?

  // ← NEW: Resend domain integration
  resendDomainId   String? // Resend's domain ID returned by resend.domains.create()
  resendStatus     String? // 'not_started' | 'pending' | 'verified' | 'failed'
  resendDnsRecords Json?   // DNS records array from Resend — shown in setup UI

  // Reputation
  reputationScore     Int       @default(100)
  reputationUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliverabilityReports DeliverabilityReport[]

  @@unique([workspaceId, domain])
  @@index([workspaceId])
  @@map("sending_domains")
}

// ---------------------------------------------------------------------------
// DELIVERABILITY REPORT
// ---------------------------------------------------------------------------

model DeliverabilityReport {
  id         String  @id @default(cuid())
  campaignId String  @unique
  domainId   String?

  score    Int
  warnings String @default("[]")
  details  String @default("{}")

  createdAt DateTime @default(now())

  campaign EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  domain   SendingDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  @@map("deliverability_reports")
}

// ---------------------------------------------------------------------------
// INBOX TEST RESULT
// ---------------------------------------------------------------------------

model InboxTestResult {
  id         String @id @default(cuid())
  campaignId String
  provider   String
  placement  String

  testedAt DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("inbox_test_results")
}

// ===========================================================================
// AUTOMATION SYSTEM
// ===========================================================================

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  DISABLED
}

enum AutomationStepType {
  TRIGGER
  DELAY
  SEND_EMAIL
  ADD_TAG
  WEBHOOK
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AutomationWorkflow {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      AutomationStatus @default(DRAFT)
  errorCount  Int              @default(0)

  totalRuns       Int       @default(0)
  totalEmailsSent Int       @default(0)
  lastTriggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps        AutomationStep[]
  enrollments  AutomationEnrollment[]
  jobs         AutomationJob[]
  attributions RevenueAttribution[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("automation_workflows")
}

model AutomationStep {
  id         String             @id @default(cuid())
  workflowId String
  type       AutomationStepType
  position   Int
  config     Json               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  jobs     AutomationJob[]

  @@index([workflowId, position])
  @@map("automation_steps")
}

model AutomationLog {
  id           String   @id @default(cuid())
  workspaceId  String
  workflowId   String
  enrollmentId String
  contactId    String
  stepId       String?
  event        String   // 'enrollment', 'step_start', 'step_complete', 'step_failed'
  message      String?  @db.Text
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([workflowId])
  @@index([enrollmentId])
  @@map("automation_logs")
}

model AutomationEnrollment {
  id           String           @id @default(cuid())
  workflowId   String
  contactId    String
  currentStep  Int              @default(0)
  status       EnrollmentStatus @default(ACTIVE)
  errorCount   Int              @default(0)
  errorMessage String?          @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact  Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  jobs     AutomationJob[]

  @@unique([workflowId, contactId])
  @@index([workflowId])
  @@index([contactId])
  @@index([status])
  @@map("automation_enrollments")
}

model AutomationJob {
  id           String    @id @default(cuid())
  workflowId   String
  stepId       String
  enrollmentId String
  executeAt    DateTime
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow   AutomationWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  step       AutomationStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  enrollment AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([status, executeAt])
  @@index([enrollmentId])
  @@map("automation_jobs")
}

// ===========================================================================
// EMAIL TEMPLATES
// ===========================================================================

model EmailTemplate {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  category    String
  subject     String
  htmlBody    String  @db.Text
  previewText String?

  isSystemTemplate Boolean @default(false)
  isPublic         Boolean @default(false)
  price            Int     @default(0)

  usageCount   Int   @default(0)
  avgOpenRate  Float @default(0)
  avgClickRate Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@map("email_templates")
}

// ===========================================================================
// SEGMENTATION
// ===========================================================================

model Segment {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  description String?
  rules       String  @default("{}")

  contactCount    Int       @default(0)
  lastEvaluatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("segments")
}

// ===========================================================================
// REVENUE ATTRIBUTION
// ===========================================================================

model Purchase {
  id          String  @id @default(cuid())
  workspaceId String
  contactId   String?
  email       String
  productId   String?
  productName String?
  amount      Int
  currency    String  @default("usd")
  source      String  @default("api")
  externalId  String?
  metadata    Json?

  createdAt DateTime @default(now())

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  attributions RevenueAttribution[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@index([contactId])
  @@index([workspaceId, createdAt])
  @@map("purchases")
}

model ClickEvent {
  id          String   @id @default(cuid())
  workspaceId String
  campaignId  String
  contactId   String
  url         String   @db.Text
  clickedAt   DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact   Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([contactId])
  @@index([campaignId, contactId])
  @@map("click_events")
}

model RevenueAttribution {
  id               String  @id @default(cuid())
  workspaceId      String
  purchaseId       String
  contactId        String?
  campaignId       String?
  workflowId       String?
  attributionModel String  @default("last_click")
  revenue          Int

  createdAt DateTime @default(now())

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchase  Purchase            @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  contact   Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign  EmailCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  workflow  AutomationWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([workflowId])
  @@index([contactId])
  @@index([purchaseId])
  @@map("revenue_attributions")
}

// ===========================================================================
// EMAIL PROVIDER CONFIG
// ===========================================================================

enum EmailProviderType {
  RESEND
  SES
  SENDGRID
}

model EmailProviderConfig {
  id           String            @id @default(cuid())
  workspaceId  String            @unique
  provider     EmailProviderType
  encryptedKey String            @db.Text
  metadata     String            @default("{}")
  isVerified   Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("email_provider_configs")
}

// ===========================================================================
// DOMAIN SEARCH LOG
// ===========================================================================

model DomainSearchLog {
  id          String @id @default(cuid())
  workspaceId String

  domain           String
  available        Boolean
  priceUsd         Int?
  registrarClicked String?
  clickedAt        DateTime?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
  @@map("domain_search_logs")
}

// ===========================================================================
// AI CREDIT LOG
// ===========================================================================

model AiCreditLog {
  id          String @id @default(cuid())
  workspaceId String

  delta        Int
  balanceAfter Int
  reason       String
  refId        String?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
  @@map("ai_credit_logs")
}

// ===========================================================================
// WORKSPACE ADD-ONS
// ===========================================================================

enum AddonType {
  emails
  contacts
  ai_credits
}

model WorkspaceAddon {
  id          String    @id @default(cuid())
  workspaceId String
  type        AddonType
  quantity    Int
  whopMembershipId String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@map("workspace_addons")
}

model WebhookLog {
  id              String   @id @default(cuid())
  workspaceId     String
  externalEventId String?  @unique // Whop event ID for idempotency
  action          String
  payload         Json
  status          Int      @default(200)
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("webhook_logs")
}

enum NotificationType {
  SYSTEM
  BILLING
  CAMPAIGN
  IMPORT
  AI
}

model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String?          // Target specific user if needed
  type        NotificationType @default(SYSTEM)
  title       String
  message     String           @db.Text
  actionUrl   String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, isRead])
  @@index([workspaceId, createdAt])
  @@map("notifications")
}
