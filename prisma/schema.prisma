// prisma/schema.prisma
//
// Whop Email Engine — Full Database Schema (Phase 2)
//
// Database Principles enforced:
//   ✅ Every tenant-scoped table includes workspaceId
//   ✅ UUIDs for all primary keys
//   ✅ createdAt + updatedAt on all tables
//   ✅ Foreign keys indexed
//   ✅ Unique constraint: (workspaceId, email) on Contact
//   ✅ Schema designed for high-volume email sends
//   ✅ Future-ready for segmentation, webhooks, automation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// AUTH — NextAuth v5 / Auth.js adapter tables
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?   // null for OAuth-only users
  hasAchievedFirstSend Boolean @default(false)
  onboardingDismissedAt DateTime? // set when user explicitly dismisses the onboarding checklist

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts    Account[]
  sessions    Session[]
  memberships WorkspaceMembership[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// WORKSPACE — Top-level multi-tenant boundary
// ---------------------------------------------------------------------------

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique // URL-safe identifier, e.g. "acme-corp"

  // Whop integration — stored per workspace for isolation
  whopApiKey      String? // encrypted at rest in production
  whopCompanyId   String?
  webhookSecret   String? // per-workspace secret for Whop webhook verification // Whop company/product ID for this workspace

  // Sending identity defaults
  fromEmail String?
  fromName  String?

  // Plan / limits (extended in billing phase)
  plan            WorkspacePlan @default(FREE)
  monthlyEmailCap Int           @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships WorkspaceMembership[]
  contacts    Contact[]
  campaigns   EmailCampaign[]
  emailSends  EmailSend[]
  syncLogs    SyncLog[]
  apiKeys         ApiKey[]
  telemetryEvents   TelemetryEvent[]
  sendingDomains      SendingDomain[]
  automationWorkflows AutomationWorkflow[]
  segments            Segment[]
  purchases           Purchase[]
  attributions        RevenueAttribution[]
  emailTemplates      EmailTemplate[]
  tags        Tag[]

  @@index([slug])
  @@map("workspaces")
}

enum WorkspacePlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ---------------------------------------------------------------------------
// WORKSPACE MEMBERSHIP — User <-> Workspace many-to-many with roles
// ---------------------------------------------------------------------------

model WorkspaceMembership {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_memberships")
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ---------------------------------------------------------------------------
// CONTACT — A synced member/subscriber scoped to a workspace
// ---------------------------------------------------------------------------

model Contact {
  id          String @id @default(cuid())
  workspaceId String

  // Identity
  email     String
  firstName String?
  lastName  String?

  // Whop sync metadata
  whopMemberId String? // Whop's user ID — used for idempotent re-syncs
  whopMetadata Json?   // Raw Whop fields (product access, plan, etc.)

  // Subscription state
  status ContactStatus @default(SUBSCRIBED)

  // Unsubscribe tracking
  unsubscribedAt DateTime?
  unsubscribeIp  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags                  ContactTag[]
  emailSends            EmailSend[]
  automationEnrollments AutomationEnrollment[]
  purchases             Purchase[]
  attributions          RevenueAttribution[]

  // CRITICAL: prevents duplicate contacts per workspace (database-principles.md)
  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([whopMemberId])
  @@map("contacts")
}

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

// ---------------------------------------------------------------------------
// TAG — Workspace-scoped label for contact segmentation
// ---------------------------------------------------------------------------

model Tag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// ---------------------------------------------------------------------------
// EMAIL CAMPAIGN — A single campaign definition
// ---------------------------------------------------------------------------

model EmailCampaign {
  id          String @id @default(cuid())
  workspaceId String

  name        String
  type        CampaignType   @default(BROADCAST)
  status      CampaignStatus @default(DRAFT)

  // Content
  subject     String
  previewText String?
  htmlBody    String  @db.Text
  textBody    String? @db.Text

  // Audience — tag-based and segment-based targeting
  audienceTagIds     String[]
  audienceSegmentIds String[]

  // A/B testing
  isAbTest        Boolean @default(false)
  templateId      String? // links to EmailTemplate if created from one
  abSubjectB      String?
  abWinnerVariant String?

  // Scheduling
  scheduledAt DateTime?
  sentAt      DateTime?

  // Stats cache — updated asynchronously
  totalRecipients Int @default(0)
  totalSent       Int @default(0)
  totalOpened     Int @default(0)
  totalClicked    Int @default(0)
  totalBounced    Int @default(0)
  totalFailed     Int @default(0)
  totalRevenue    Int @default(0) // cents — updated by attribution engine

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  emailSends           EmailSend[]
  attributions         RevenueAttribution[]
  deliverabilityReport DeliverabilityReport?
  inboxTestResults     InboxTestResult[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([scheduledAt])
  @@map("email_campaigns")
}

enum CampaignType {
  BROADCAST
  DRIP
  TRIGGER
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  PAUSED
}

// ---------------------------------------------------------------------------
// EMAIL SEND — One row per recipient per campaign (the send audit trail)
// High-volume table — every send creates a row
// ---------------------------------------------------------------------------

model EmailSend {
  id          String @id @default(cuid())
  workspaceId String
  campaignId  String
  contactId   String

  // Delivery state
  status   EmailSendStatus @default(PENDING)
  provider EmailProvider   @default(RESEND)

  // Provider response
  messageId     String?
  failureReason String? @db.Text

  // Idempotency key — prevents duplicate sends
  // Format: "{campaignId}:{contactId}"
  idempotencyKey String @unique

  // Tracking timestamps
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?

  // Bounce details (populated by webhook)
  bounceType   String? // e.g. "hard", "soft"
  bounceReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign  EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact   Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([contactId])
  @@index([workspaceId, status])
  @@index([idempotencyKey])
  @@index([messageId])
  @@map("email_sends")
}

enum EmailSendStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  UNSUBSCRIBED
}

enum EmailProvider {
  RESEND
  SMTP
}

// ---------------------------------------------------------------------------
// SYNC LOG — Audit trail for Whop member sync operations
// ---------------------------------------------------------------------------

model SyncLog {
  id          String @id @default(cuid())
  workspaceId String

  status      SyncStatus @default(RUNNING)
  triggeredBy String?    // userId or "system"

  // Results
  totalFetched  Int @default(0)
  totalUpserted Int @default(0)
  totalSkipped  Int @default(0)
  totalErrors   Int @default(0)

  errorDetails Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// NOTE: bounceType and bounceReason added for webhook ingestion
// Run: prisma migrate dev --name add_bounce_fields

// ---------------------------------------------------------------------------
// API KEY — User-generated keys for external API / agent access
// ---------------------------------------------------------------------------

model ApiKey {
  id          String  @id @default(cuid())
  workspaceId String
  name        String  // human label e.g. 'My Agent'
  keyHash     String  @unique // bcrypt hash of the full key
  keyPrefix   String  // first 8 chars shown in UI e.g. 'wee_1234'
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs      ApiLog[]

  @@index([workspaceId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// API LOG — Audit trail for every v1 API call
// ---------------------------------------------------------------------------

model ApiLog {
  id         String @id @default(cuid())
  apiKeyId   String
  method     String // GET POST etc
  path       String // /api/v1/campaigns
  statusCode Int
  durationMs Int

  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
  @@map("api_logs")
}

// ---------------------------------------------------------------------------
// TELEMETRY EVENT — Lightweight behavioral event log for analytics + future ML
// Append-only. Never updated. Index on (workspaceId, event, createdAt).
// ---------------------------------------------------------------------------

model TelemetryEvent {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String? // null for system-generated events

  // Event name — use snake_case e.g. 'campaign_created'
  event       String

  // Arbitrary JSON properties for future ML feature extraction.
  // Stored as String to avoid Prisma JSON type edge cases on all DB providers.
  // Parse with JSON.parse() when reading.
  properties  String  @default("{}")

  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, event, createdAt])
  @@index([createdAt])
  @@map("telemetry_events")
}

// ---------------------------------------------------------------------------
// SENDING DOMAIN — Per-workspace domain auth + reputation cache
// ---------------------------------------------------------------------------

model SendingDomain {
  id          String  @id @default(cuid())
  workspaceId String
  domain      String  // e.g. "acme.com"

  // DNS authentication status
  spfVerified   Boolean @default(false)
  dkimVerified  Boolean @default(false)
  dkimSelector  String  @default("wee1") // DNS TXT record selector
  dkimPublicKey String? @db.Text // published in DNS TXT record
  dkimPrivateKey String? @db.Text // encrypted, used for signing

  // Reputation (computed + cached by reputation engine)
  reputationScore     Int       @default(100)
  reputationUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliverabilityReports DeliverabilityReport[]

  @@unique([workspaceId, domain])
  @@index([workspaceId])
  @@map("sending_domains")
}

// ---------------------------------------------------------------------------
// DELIVERABILITY REPORT — Pre-send check result per campaign
// ---------------------------------------------------------------------------

model DeliverabilityReport {
  id         String  @id @default(cuid())
  campaignId String  @unique
  domainId   String?

  score    Int    // 0–100
  warnings String @default("[]") // JSON array of warning strings
  details  String @default("{}") // JSON — spam score, auth status, etc.

  createdAt DateTime @default(now())

  campaign EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  domain   SendingDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  @@map("deliverability_reports")
}

// ---------------------------------------------------------------------------
// INBOX TEST RESULT — Simulated seed list placement results
// ---------------------------------------------------------------------------

model InboxTestResult {
  id         String @id @default(cuid())
  campaignId String
  provider   String // gmail | outlook | yahoo
  placement  String // inbox | spam | promotions

  testedAt DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("inbox_test_results")
}

// ===========================================================================
// AUTOMATION SYSTEM
// ===========================================================================

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  DISABLED
}

enum AutomationStepType {
  TRIGGER
  DELAY
  SEND_EMAIL
  ADD_TAG
  WEBHOOK
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ---------------------------------------------------------------------------
// AUTOMATION WORKFLOW
// ---------------------------------------------------------------------------

model AutomationWorkflow {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      AutomationStatus @default(DRAFT)
  errorCount  Int              @default(0)

  // Stats
  totalRuns       Int       @default(0)
  totalEmailsSent Int       @default(0)
  lastTriggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps        AutomationStep[]
  enrollments  AutomationEnrollment[]
  jobs         AutomationJob[]
  attributions RevenueAttribution[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("automation_workflows")
}

// ---------------------------------------------------------------------------
// AUTOMATION STEP — one node in the workflow
// config is JSON stored as String:
//   TRIGGER:    { triggerType: 'new_member'|'purchase'|'api'|'manual', filters?: {} }
//   DELAY:      { amount: number, unit: 'minutes'|'hours'|'days' }
//   SEND_EMAIL: { subject: string, html: string, fromName?: string }
//   ADD_TAG:    { tagName: string }
//   WEBHOOK:    { url: string, method: 'GET'|'POST', payload?: string }
// ---------------------------------------------------------------------------

model AutomationStep {
  id         String             @id @default(cuid())
  workflowId String
  type       AutomationStepType
  position   Int
  config     String             @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  jobs     AutomationJob[]

  @@index([workflowId, position])
  @@map("automation_steps")
}

// ---------------------------------------------------------------------------
// AUTOMATION ENROLLMENT — one contact's journey through a workflow
// ---------------------------------------------------------------------------

model AutomationEnrollment {
  id           String           @id @default(cuid())
  workflowId   String
  contactId    String
  currentStep  Int              @default(0) // position of next step to execute
  status       EnrollmentStatus @default(ACTIVE)
  errorCount   Int              @default(0)
  errorMessage String?          @db.Text

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact  Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  jobs     AutomationJob[]

  // One active enrollment per contact per workflow
  @@unique([workflowId, contactId])
  @@index([workflowId])
  @@index([contactId])
  @@index([status])
  @@map("automation_enrollments")
}

// ---------------------------------------------------------------------------
// AUTOMATION JOB — a scheduled step execution (used for delays)
// ---------------------------------------------------------------------------

model AutomationJob {
  id           String    @id @default(cuid())
  workflowId   String
  stepId       String
  enrollmentId String
  executeAt    DateTime
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow   AutomationWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  step       AutomationStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  enrollment AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([status, executeAt])
  @@index([enrollmentId])
  @@map("automation_jobs")
}

// ===========================================================================
// EMAIL TEMPLATES
// ===========================================================================

model EmailTemplate {
  id          String  @id @default(cuid())
  workspaceId String  // null-equivalent: use a sentinel workspace for system templates
  name        String
  category    String  // 'course_launch' | 'promotion' | 'announcement' etc.
  subject     String
  htmlBody    String  @db.Text
  previewText String?

  // Ownership flags
  isSystemTemplate Boolean @default(false) // system templates are read-only
  isPublic         Boolean @default(false) // future marketplace
  price            Int     @default(0)     // future marketplace (cents)

  // Stats (updated when campaigns using this template complete)
  usageCount  Int @default(0)
  avgOpenRate Float @default(0)
  avgClickRate Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@map("email_templates")
}

// ===========================================================================
// SEGMENTATION SYSTEM
// ===========================================================================

// ---------------------------------------------------------------------------
// SEGMENT — a saved filter that dynamically resolves to a set of contacts
//
// rules JSON shape:
// {
//   operator: 'AND' | 'OR',
//   conditions: [
//     { field: 'tag',          op: 'has' | 'not_has',     value: 'buyer' },
//     { field: 'status',       op: 'eq',                  value: 'SUBSCRIBED' },
//     { field: 'createdAt',    op: 'within_days',         value: 30 },
//     { field: 'lastOpened',   op: 'within_days' | 'never', value: 30 },
//     { field: 'lastClicked',  op: 'within_days' | 'never', value: 30 },
//     { field: 'opensCount',   op: 'gt' | 'lt',           value: 3 },
//     { field: 'emailsSent',   op: 'gt' | 'lt',           value: 5 }
//   ]
// }
// ---------------------------------------------------------------------------

model Segment {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  description String?
  rules       String  @default("{}") // JSON

  // Cached contact count — updated when segment is previewed or used
  contactCount    Int       @default(0)
  lastEvaluatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("segments")
}

// ===========================================================================
// REVENUE ATTRIBUTION SYSTEM
// ===========================================================================

model Purchase {
  id          String  @id @default(cuid())
  workspaceId String
  contactId   String?  // nullable — contact may not be in system yet
  email       String   // always store for matching
  productId   String?
  productName String?
  amount      Int      // cents
  currency    String   @default("usd")
  source      String   @default("api") // 'whop' | 'api' | 'webhook'
  externalId  String?  // for idempotent dedup
  metadata    Json?

  createdAt DateTime @default(now())

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  attributions RevenueAttribution[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@index([contactId])
  @@index([workspaceId, createdAt])
  @@map("purchases")
}

model RevenueAttribution {
  id               String  @id @default(cuid())
  workspaceId      String
  purchaseId       String
  contactId        String?
  campaignId       String?
  workflowId       String?
  attributionModel String  @default("last_click")
  revenue          Int     // cents

  createdAt DateTime @default(now())

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchase  Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  contact   Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign  EmailCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  workflow  AutomationWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([campaignId])
  @@index([workflowId])
  @@index([contactId])
  @@index([purchaseId])
  @@map("revenue_attributions")
}
